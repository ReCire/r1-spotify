  }
  if (state.discographyFilter === 'all' || state.discographyFilter === 'related') {
    state.artistData.related.forEach(a => {
      allItems.push({ name: a.name, artist: '', image: a.image, type: 'artist', id: a.id, uri: a.uri, filterType: 'related' });
