* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

html, body {
  width: 240px;
  height: 282px;
  background-color: #0e0e10;
  color: #fff;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  font-size: 12px;
  overflow: hidden;
  -webkit-user-select: none;
  user-select: none;
}

#app {
  width: 240px;
  height: 282px;
  display: flex;
  flex-direction: column;
  position: relative;
}

/* ========== Header ========== */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 5px 8px;
  flex-shrink: 0;
  height: 26px;
}

.logo {
  width: 18px;
  height: 18px;
  color: #fff;
}

.nav-tabs {
  display: flex;
  gap: 2px;
}

.nav-tab {
  background: none;
  border: none;
  color: #666;
  font-size: 8px;
  font-weight: 700;
  padding: 3px 6px;
  border-radius: 3px;
  cursor: pointer;
  text-transform: uppercase;
  display: flex;
  align-items: center;
  gap: 3px;
  -webkit-tap-highlight-color: transparent;
}

.nav-tab.active {
  color: #fff;
  background: #1a1a1a;
}

.live-dot {
  width: 5px;
  height: 5px;
  background: #ff0000;
  border-radius: 50%;
  animation: pulse 1.5s infinite;
  display: inline-block;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

/* ========== Station List (Live) ========== */
.station-list {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding: 2px 6px 6px;
  overflow: hidden;
  position: relative;
}

/* Cross-tab now-playing bar (flex child at top of station list) */
.cross-tab-np {
  flex-shrink: 0;
  overflow: hidden;
  max-height: 0;
  opacity: 0;
  border-radius: 6px;
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 0 8px;
  background: rgba(14, 14, 16, 0.92);
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
  border: 1px solid #FE5F00;
  cursor: pointer;
  transition: max-height 0.35s cubic-bezier(0.25, 0.1, 0.25, 1),
              opacity 0.25s ease,
              padding 0.35s ease;
}
.cross-tab-np.visible {
  max-height: 36px;
  opacity: 1;
  padding: 6px 8px;
}
.cross-tab-np .np-art {
  width: 24px;
  height: 24px;
  border-radius: 4px;
  object-fit: cover;
  flex-shrink: 0;
}
.cross-tab-np .np-name {
  font-size: 9px;
  font-weight: 700;
  flex: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.cross-tab-np .np-indicator {
  font-size: 7px;
  color: #FE5F00;
  font-weight: 700;
  letter-spacing: 0.5px;
  flex-shrink: 0;
}

.station-card {
  flex: 1;
  border-radius: 8px;
  background: #1a1a1a;
  background-size: cover;
  background-position: center;
  position: relative;
  overflow: hidden;
  cursor: pointer;
  -webkit-tap-highlight-color: transparent;
  transition: flex 0.4s cubic-bezier(0.25, 0.1, 0.25, 1);
}

.station-card.expanded {
  flex: 2.5;
}

/* Gradient overlay on card */
.card-overlay {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(to bottom, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0) 40%),
    linear-gradient(to top, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0) 40%);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 8px;
}

/* Top info group */
.card-top {
  display: flex;
  flex-direction: column;
  gap: 1px;
}

.card-station-name {
  font-size: 9px;
  font-weight: 700;
  color: #FE5F00;
  text-shadow: 0 1px 3px rgba(0,0,0,0.8);
}

.card-title {
  font-size: 10px;
  font-weight: 700;
  line-height: 1.2;
  text-shadow: 0 1px 3px rgba(0,0,0,0.8);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* Play/pause button centered on art */
.card-play-btn {
  width: 32px;
  height: 32px;
  min-width: 32px;
  min-height: 32px;
  flex-shrink: 0;
  border-radius: 50%;
  background: rgba(254, 95, 0, 0.9);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #000;
  cursor: pointer;
  align-self: center;
  -webkit-tap-highlight-color: transparent;
  transition: transform 0.1s;
}

.card-play-btn:active {
  transform: scale(0.9);
}

.card-play-btn svg {
  width: 14px;
  height: 14px;
}

/* Bottom info */
.card-bottom {
  display: flex;
  flex-direction: column;
}

.card-desc {
  font-size: 8px;
  color: #ddd;
  line-height: 1.3;
  text-shadow: 0 1px 2px rgba(0,0,0,0.8);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.card-bottom.expanded .card-desc {
  white-space: normal;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* Visualizer on active card */
.card-visualizer {
  position: absolute;
  top: 6px;
  right: 8px;
  display: flex;
  align-items: flex-end;
  gap: 2px;
  height: 14px;
}

.viz-bar {
  width: 2px;
  height: 30%;
  background: #FE5F00;
  border-radius: 1px;
  transition: height 0.15s ease;
}

/* ========== Mixtapes ========== */
.mixtape-container {
  flex: 1;
  position: relative;
  overflow: hidden;
  padding: 0 6px;
}

.mixtape-card {
  position: absolute;
  left: 6px;
  right: 6px;
  border-radius: 8px;
  background: #1a1a1a;
  background-size: cover;
  background-position: center;
  overflow: hidden;
  cursor: pointer;
  -webkit-tap-highlight-color: transparent;
  will-change: transform, opacity;
  transition: transform 0.35s cubic-bezier(0.25, 0.1, 0.25, 1),
              opacity 0.35s ease,
              height 0.35s cubic-bezier(0.25, 0.1, 0.25, 1);
}

.mixtape-card.playing {
  box-shadow: inset 0 0 0 1px #FE5F00;
}

.mixtape-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to bottom,
    rgba(0,0,0,0.3) 0%,
    rgba(0,0,0,0.1) 40%,
    rgba(0,0,0,0.75) 100%
  );
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  align-items: center;
  padding: 8px;
}

.mixtape-overlay .card-play-btn {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  transition: opacity 0.2s ease;
}

.mixtape-info {
  width: 100%;
  text-align: center;
}

.mixtape-name {
  font-size: 11px;
  font-weight: 700;
  text-shadow: 0 1px 3px rgba(0,0,0,0.8);
}

.mixtape-desc {
  font-size: 8px;
  color: #ccc;
  margin-top: 2px;
  line-height: 1.3;
  text-shadow: 0 1px 2px rgba(0,0,0,0.8);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  transition: opacity 0.2s ease;
}

.scroll-indicator {
  position: absolute;
  bottom: 4px;
  right: 10px;
  font-size: 8px;
  color: #666;
  font-weight: 600;
  z-index: 5;
}

/* Sticky now-playing bar */
.mixtape-now-playing {
  position: absolute;
  left: 6px;
  right: 6px;
  height: 36px;
  border-radius: 6px;
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 0 8px;
  background: rgba(14, 14, 16, 0.92);
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
  border: 1px solid #FE5F00;
  z-index: 10;
  cursor: pointer;
  transition: opacity 0.25s ease, transform 0.25s ease;
}
.mixtape-now-playing.at-top { top: 2px; }
.mixtape-now-playing.at-bottom { bottom: 18px; }
.mixtape-now-playing .np-art {
  width: 24px;
  height: 24px;
  border-radius: 4px;
  object-fit: cover;
}
.mixtape-now-playing .np-name {
  font-size: 9px;
  font-weight: 700;
  flex: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.mixtape-now-playing .np-indicator {
  font-size: 8px;
  color: #FE5F00;
  font-weight: 700;
}

/* ========== Volume Toast (floating) ========== */
.volume-toast {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0.9);
  background: rgba(0, 0, 0, 0.9);
  border: 1px solid #333;
  border-radius: 8px;
  padding: 8px 12px;
  display: flex;
  align-items: center;
  gap: 6px;
  z-index: 200;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.2s, transform 0.2s;
}

.volume-toast.visible {
  opacity: 1;
  transform: translate(-50%, -50%) scale(1);
}

.vol-icon-sm {
  font-size: 12px;
}

.vol-track-sm {
  width: 80px;
  height: 4px;
  background: #333;
  border-radius: 2px;
  overflow: hidden;
}

.vol-fill-sm {
  height: 100%;
  background: #FE5F00;
  border-radius: 2px;
  transition: width 0.1s;
}

.vol-pct-sm {
  font-size: 10px;
  color: #999;
  min-width: 28px;
  text-align: right;
}

/* ========== Toast Messages ========== */
.toast {
  position: absolute;
  bottom: 30px;
  left: 50%;
  transform: translateX(-50%);
  color: #fff;
  font-size: 9px;
  font-weight: 500;
  padding: 5px 10px;
  border-radius: 6px;
  max-width: 210px;
  text-align: center;
  z-index: 100;
