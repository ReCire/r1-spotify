.mini-art {
  width: 24px;
  height: 24px;
  border-radius: 4px;
  object-fit: cover;
  background: #121212;
  flex-shrink: 0;
}

.mini-info {
  flex: 1;
  min-width: 0;
}

.mini-name {
  font-size: 9px;
  font-weight: 700;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  color: #fff;
}

.mini-indicator {
  font-size: 8px;
  color: #1DB954;
  font-weight: 700;
  flex-shrink: 0;
  letter-spacing: 0.5px;
}

/* ========== List Container ========== */
.list-container {
  flex: 1;
  overflow-y: auto;
  overflow-x: hidden;
}

.list-container.with-player {
  padding-bottom: 60px;
}

/* ========== Now Playing View ========== */
.view-nowplaying {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 6px 12px 10px;
  background: linear-gradient(180deg, #1a1a1a 0%, #121212 40%);
}

.np-header {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 6px;
}

.np-back {
  width: 20px;
  height: 20px;
  background: none;
  border: none;
  color: #b3b3b3;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  -webkit-tap-highlight-color: transparent;
}

.np-back svg {
  width: 16px;
  height: 16px;
}

.np-context {
  font-size: 8px;
  color: #b3b3b3;
  font-weight: 600;
  letter-spacing: 0.3px;
  text-transform: uppercase;
}

.np-artwork {
  width: 140px;
  height: 140px;
  margin: 0 auto 8px;
  border-radius: 6px;
  overflow: hidden;
  background: #282828;
  box-shadow: 0 4px 20px rgba(0,0,0,0.5);
}

.np-artwork img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.np-artwork-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.np-artwork-placeholder svg {
  width: 40px;
  height: 40px;
}

.np-track-info {
  text-align: center;
  margin-bottom: 6px;
}

.np-track-name {
  font-size: 11px;
  font-weight: 700;
  line-height: 1.3;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.np-track-artist {
  font-size: 9px;
  color: #b3b3b3;
  margin-top: 1px;
}

.np-progress {
  margin-bottom: 6px;
}

.progress-track {
  width: 100%;
  height: 3px;
  background: #535353;
  border-radius: 2px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #1DB954;
  border-radius: 2px;
  transition: width 0.4s linear;
}

.track-time {
  font-size: 7px;
  color: #b3b3b3;
  text-align: center;
  margin-top: 3px;
}

.np-controls {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16px;
}

.ctrl-btn {
  width: 28px;
  height: 28px;
  background: none;
  border: none;
  color: #fff;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  -webkit-tap-highlight-color: transparent;
  transition: transform 0.1s;
}

.ctrl-btn:active {
  transform: scale(0.9);
}

.ctrl-btn svg {
  width: 20px;
  height: 20px;
}

.ctrl-play {
  width: 36px;
  height: 36px;
  background: #1DB954;
  color: #000;
  border-radius: 50%;
}

.ctrl-play:active {
  background: #1ed760;
}

.ctrl-play svg {
  width: 18px;
  height: 18px;
}

/* ========== Search ========== */
.search-box {
  padding: 4px 8px;
  flex-shrink: 0;
}

.search-input {
  width: 100%;
  height: 24px;
  background: #282828;
  border: none;
  border-radius: 4px;
  padding: 0 8px;
  font-size: 10px;
  color: #fff;
  outline: none;
  font-family: inherit;
}

.search-input::placeholder {
  color: #535353;
}

.search-input:focus {
  background: #333;
}

/* ========== Volume Toast ========== */
.volume-toast {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0.9);
  background: rgba(40, 40, 40, 0.95);
  border-radius: 8px;
  padding: 8px 14px;
  display: flex;
  align-items: center;
  gap: 8px;
  z-index: 200;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.2s, transform 0.2s;
}

.volume-toast.visible {
  opacity: 1;
  transform: translate(-50%, -50%) scale(1);
}

.vol-track-sm {
  width: 80px;
  height: 3px;
  background: #535353;
  border-radius: 2px;
  overflow: hidden;
}

.vol-fill-sm {
  height: 100%;
  background: #1DB954;
  border-radius: 2px;
  transition: width 0.1s;
}

.vol-pct-sm {
  font-size: 9px;
  color: #b3b3b3;
  min-width: 24px;
  text-align: right;
}

/* ========== Toast Messages ========== */
.toast {
  position: absolute;
  bottom: 40px;
  left: 50%;
  transform: translateX(-50%);
  color: #fff;
  font-size: 9px;
  font-weight: 500;
  padding: 5px 10px;
  border-radius: 4px;
  max-width: 200px;
  text-align: center;
  z-index: 100;
  animation: toastIn 0.25s ease;
  line-height: 1.3;
}

.toast-error { background: #e22134; }
.toast-warning { background: #f59b23; color: #000; }
.toast-info { background: #282828; }

@keyframes toastIn {
  from { opacity: 0; transform: translateX(-50%) translateY(4px); }
  to { opacity: 1; transform: translateX(-50%) translateY(0); }
}
